{
  "name": "subster",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Subster — a backend-free Hitster clone that plays your Subsonic library.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/status-bar": "^6.0.3",
    "@jofr/capacitor-media-session": "^4.0.0",
    "blueimp-md5": "^2.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@types/blueimp-md5": "^2.18.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.2"
  },
  "overrides": {
    "workbox-build": "7.3.0",
    "workbox-window": "7.3.0"
  }
}
